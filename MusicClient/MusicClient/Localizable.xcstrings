    "settings.sync.footer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Syncs albums and songs from your Jellyfin server. This happens automatically when you first log in."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronisiert Alben und Songs von deinem Jellyfin-Server. Dies geschieht automatisch bei der ersten Anmeldung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincroniza álbumes y canciones desde tu servidor Jellyfin. Esto ocurre automáticamente cuando inicias sesión por primera vez."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Synkronoi albumit ja kappaleet Jellyfin-palvelimeltasi. Tämä tapahtuu automaattisesti ensimmäisen kirjautumisen yhteydessä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronise les albums et les chansons depuis votre serveur Jellyfin. Cela se fait automatiquement lors de votre première connexion."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincronizza album e brani dal tuo server Jellyfin. Questo avviene automaticamente al primo accesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Jellyfinサーバーからアルバムと曲を同期します。初回ログイン時に自動的に行われます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Synkroniserer album og sanger fra Jellyfin-serveren din. Dette skjer automatisk når du logger inn for første gang."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchroniseert albums en nummers van je Jellyfin-server. Dit gebeurt automatisch wanneer je voor het eerst inlogt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincroniza álbuns e músicas do seu servidor Jellyfin. Isso acontece automaticamente no primeiro login."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
