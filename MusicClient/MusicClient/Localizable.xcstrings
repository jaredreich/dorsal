    "settings.storage.clear_album_art.message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will clear all cached album art. Art for downloaded albums will be kept. Album art will be re-downloaded as you browse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle zwischengespeicherten Albumcover gelöscht. Cover geladener Alben bleiben erhalten. Albumcover werden beim Durchsuchen erneut geladen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se borrarán todas las carátulas en caché. Las carátulas de los álbumes descargados se conservarán. Se volverán a descargar mientras navegas."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaikki välimuistissa olevat kansikuvat tyhjennetään. Ladattujen albumien kansikuvat säilytetään. Kansikuvat ladataan uudelleen selatessasi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela effacera toutes les pochettes en cache. Les pochettes des albums téléchargés seront conservées. Elles seront téléchargées à nouveau lors de la navigation."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutte le copertine nella cache verranno cancellate. Le copertine degli album scaricati saranno conservate. Le copertine verranno scaricate nuovamente durante la navigazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャッシュ済みのアートワークをすべて消去します。ダウンロード済みアルバムのアートワークは保持されます。アートワークは閲覧時に再ダウンロードされます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle hurtiglagrede albumomslag tømmes. Omslag for nedlastede album beholdes. Albumomslag lastes ned på nytt når du blar."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle gecachte albumhoezen worden gewist. Hoezen van gedownloade albums blijven behouden. Albumhoezen worden opnieuw gedownload tijdens het browsen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as capas em cache serão removidas. As capas de álbuns baixados serão mantidas. As capas serão baixadas novamente conforme você navega."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as capas em cache serão removidas. As capas de álbuns descarregados serão mantidas. As capas serão descarregadas novamente à medida que navega."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Alla cachade albumomslag rensas. Omslag för nedladdade album behålls. Albumomslag laddas ner igen när du bläddrar."
          }
        }
      }
    },
    "settings.storage.clear_cache": {
