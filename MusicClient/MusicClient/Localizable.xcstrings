    "album.clear_cache_alert.message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will clear all cached songs from this album."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle zwischengespeicherten Songs dieses Albums gelöscht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se eliminarán todas las canciones en caché de este álbum."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä poistaa kaikki tämän albumin välimuistissa olevat kappaleet."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera toutes les chansons en cache de cet album."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verranno rimossi tutti i brani nella cache di questo album."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアルバムのキャッシュ済みの曲をすべて削除します。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette fjerner alle hurtiglagrede sanger fra dette albumet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiermee worden alle gecachte nummers van dit album verwijderd."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as músicas em cache deste álbum serão removidas."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as músicas em cache deste álbum serão removidas."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta raderar alla cachade låtar från det här albumet."
          }
        }
      }
    },
