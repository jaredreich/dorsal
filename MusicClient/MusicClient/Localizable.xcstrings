    "album.undownload_alert.message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will undownload the album. It will no longer be protected from cache clearing."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Album wird nicht mehr offline verfügbar sein und beim Leeren des Cache nicht mehr geschützt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se eliminará la descarga del álbum. Ya no estará protegido contra el borrado del caché."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Albumin lataus poistetaan. Sitä ei enää suojata välimuistin tyhjentämiseltä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'album ne sera plus téléchargé et ne sera plus protégé lors du vidage du cache."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il download dell’album verrà rimosso. Non sarà più protetto dalla pulizia della cache."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アルバムのダウンロードを削除します。キャッシュの消去から保護されなくなります。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Nedlastingen av albumet fjernes. Det vil ikke lenger være beskyttet mot tømming av hurtiglageret."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De download van het album wordt verwijderd. Het wordt niet langer beschermd tegen het wissen van de cache."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O download do álbum será removido. Ele não será mais protegido contra a limpeza do cache."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O descarregamento do álbum será removido. Deixará de estar protegido contra a limpeza da cache."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nedladdningen av albumet tas bort. Det skyddas inte längre från cacherensning."
          }
        }
      }
    },
