    "settings.storage.clear_cache.message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will clear all cached songs. You can re-cache songs by playing them again or saving the album as downloaded."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle zwischengespeicherten Songs gelöscht. Du kannst Songs erneut zwischenspeichern, indem du sie abspielst oder das Album lädst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se borrarán todas las canciones en caché. Puedes volver a guardarlas reproduciéndolas de nuevo o descargando el álbum."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaikki välimuistissa olevat kappaleet tyhjennetään. Voit tallentaa kappaleet uudelleen toistamalla niitä tai lataamalla albumin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela effacera toutes les chansons en cache. Vous pouvez les remettre en cache en les écoutant à nouveau ou en téléchargeant l'album."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti i brani nella cache verranno cancellati. Puoi salvare nuovamente i brani riproducendoli o scaricando l’album."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャッシュ済みの曲をすべて消去します。曲を再生するかアルバムをダウンロードすると再びキャッシュされます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle hurtiglagrede sanger tømmes. Du kan hurtiglagre sanger igjen ved å spille dem eller laste ned albumet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle gecachte nummers worden gewist. Je kunt nummers opnieuw cachen door ze af te spelen of het album te downloaden."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as músicas em cache serão removidas. Você pode salvar novamente as músicas reproduzindo-as ou baixando o álbum."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as músicas em cache serão removidas. Pode voltar a guardar as músicas reproduzindo-as ou descarregando o álbum."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Alla cachade låtar rensas. Du kan cacha låtar igen genom att spela dem eller ladda ner albumet."
          }
        }
      }
    },
