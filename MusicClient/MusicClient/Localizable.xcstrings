    "settings.storage.clear_downloads.message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will undownload all albums. The files can then be cleared from the cache."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle geladenen Alben entfernt. Die Dateien können anschließend aus dem Cache gelöscht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se eliminarán todos los álbumes descargados. Los archivos podrán borrarse del caché después."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaikki ladatut albumit poistetaan. Tiedostot voidaan sen jälkeen tyhjentää välimuistista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera tous les albums téléchargés. Les fichiers pourront ensuite être effacés du cache."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti gli album scaricati verranno rimossi. I file potranno poi essere cancellati dalla cache."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロード済みのアルバムをすべて削除します。その後、ファイルをキャッシュから消去できます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle nedlastede album fjernes. Filene kan deretter tømmes fra hurtiglageret."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle gedownloade albums worden verwijderd. De bestanden kunnen daarna uit de cache worden gewist."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os álbuns baixados serão removidos. Os arquivos poderão então ser limpos do cache."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os álbuns descarregados serão removidos. Os ficheiros poderão então ser limpos da cache."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Alla nedladdade album tas bort. Filerna kan sedan rensas från cachen."
          }
        }
      }
    },
