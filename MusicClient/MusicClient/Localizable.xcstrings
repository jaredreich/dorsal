    "album.download_alert.message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Download this album? It will be protected from cache clearing."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Album laden? Es wird beim Leeren des Cache geschützt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Descargar este álbum? Estará protegido contra el borrado del caché."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ladataanko tämä albumi? Se suojataan välimuistin tyhjentämiseltä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Télécharger cet album ? Il sera protégé contre le vidage du cache."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scaricare questo album? Sarà protetto dalla pulizia della cache."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアルバムをダウンロードしますか？キャッシュの消去から保護されます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Laste ned dette albumet? Det blir beskyttet mot tømming av hurtiglageret."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit album downloaden? Het wordt beschermd tegen het wissen van de cache."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Baixar este álbum? Ele será protegido contra a limpeza do cache."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Descarregar este álbum? Ficará protegido contra a limpeza da cache."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ladda ner det här albumet? Det skyddas från cacherensning."
          }
        }
      }
    },
