    "settings.storage.quality_footer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower quality uses less storage and data. Changes apply to newly cached songs."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Niedrigere Qualität benötigt weniger Speicherplatz und Daten. Änderungen gelten für neu zwischengespeicherte Songs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una calidad menor usa menos almacenamiento y datos. Los cambios se aplican a las nuevas canciones guardadas en caché."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Matalampi laatu käyttää vähemmän tallennustilaa ja dataa. Muutokset koskevat uusia välimuistiin tallennettuja kappaleita."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une qualité inférieure utilise moins de stockage et de données. Les modifications s'appliquent aux nouvelles chansons mises en cache."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una qualità inferiore utilizza meno spazio e dati. Le modifiche si applicano ai nuovi brani salvati nella cache."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "低い音質はストレージとデータ使用量を節約します。変更は新しくキャッシュされる曲に適用されます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Lavere kvalitet bruker mindre lagring og data. Endringer gjelder for nylig hurtiglagrede sanger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lagere kwaliteit gebruikt minder opslag en data. Wijzigingen gelden voor nieuw gecachte nummers."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualidade menor usa menos armazenamento e dados. As alterações se aplicam a novas músicas salvas em cache."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualidade inferior utiliza menos armazenamento e dados. As alterações aplicam-se a novas músicas guardadas em cache."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägre kvalitet använder mindre lagring och data. Ändringar gäller för nyligen cachade låtar."
          }
        }
      }
    },
