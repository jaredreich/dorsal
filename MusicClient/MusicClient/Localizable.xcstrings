            "value": "Forhåndshent neste sang"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Volgend nummer voorladen"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pré-carregar próxima música"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Pré-carregar música seguinte"
          }
        },
