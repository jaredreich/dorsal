            "state": "translated",
            "value": "Förhämta nästa låt"
          }
        }
      }
    },
    "settings.storage.prefetch_footer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatically cache the next song before the current song ends for smoother playback."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichert den nächsten Song automatisch zwischen, bevor der aktuelle endet, für einen nahtlosen Übergang."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda automáticamente en caché la siguiente canción antes de que termine la actual para una reproducción más fluida."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tallentaa seuraavan kappaleen automaattisesti välimuistiin ennen nykyisen päättymistä sujuvamman toiston varmistamiseksi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Met automatiquement en cache le morceau suivant avant la fin de la lecture pour une transition plus fluide."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva automaticamente nella cache il brano successivo prima che quello attuale finisca, per una riproduzione più fluida."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の曲が終わる前に次の曲を自動的にキャッシュし、途切れのない再生を実現します。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hurtiglagrer automatisk neste sang før den nåværende er ferdig, for jevnere avspilling."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Slaat het volgende nummer automatisch op in de cache voordat het huidige nummer eindigt, voor een vloeiendere weergave."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva automaticamente a próxima música no cache antes que a atual termine, para uma reprodução mais fluida."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda automaticamente a música seguinte na cache antes de a atual terminar, para uma reprodução mais fluida."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Cachar automatiskt nästa låt innan den nuvarande slutar för smidigare uppspelning."
          }
        }
      }
    },
